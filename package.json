{
  "name": "crx-manifest-validator",
  "version": "1.0.0",
  "description": "Validate Chrome Extension manifest.json files for common errors and best practices",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "crx-manifest-validator": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
